{
  "name": "pathfinder-studio",
  "version": "0.1.0",
  "description": "JSON schema library for .pathfinder project file format",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=junit --outputFile.junit=./junit.xml",
    "validate": "npx tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1"
  }
}
