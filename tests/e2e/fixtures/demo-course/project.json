        },
        "q4-submit": {
          "type": "button",
          "rect": { "x": 80, "y": 540, "w": 240, "h": 56 },
          "content": "Submit quiz",
          "style": {
            "backgroundColor": "#F5B041",
            "color": "#0E1726",
            "fontSize": 18,
            "fontWeight": "700"
          }
        }
      },
      "triggers": [
        {
          "id": "t-q4-submit",
          "event": { "type": "userClick", "source": "q4-submit" },
          "action": { "type": "submitQuiz", "target": "demo-quiz" },
          "priority": 0
        },
        {
          "id": "t-q4-results",
          "event": { "type": "userClick", "source": "q4-submit" },
          "action": { "type": "jumpToSlide", "target": "results" },
          "priority": 1
        }
      ]
    },
    {
      "id": "results",
      "title": "Results",
      "background": {
        "type": "gradient",
        "gradient": {
          "angle": 180,
          "stops": [
            { "offset": 0, "color": "#0E1726" },
            { "offset": 1, "color": "#1F2937" }
          ]
        }
      },
      "zOrder": ["results-badge", "results-pass", "results-fail", "results-sub"],
      "objects": {
        "results-badge": {
          "type": "image",
          "rect": { "x": 580, "y": 140, "w": 120, "h": 120 },
          "src": "media/badge.png",
          "altText": "Pathfinder completion badge"
        },
        "results-pass": {
          "type": "text",
          "rect": { "x": 140, "y": 300, "w": 1000, "h": 60 },
          "content": "You passed, %LearnerName%.",
          "style": {
            "fontSize": 44,
            "fontWeight": "700",
            "color": "#F5B041",
            "textAlign": "center"
          },
          "visibility": {
            "initial": "hidden",
            "conditional": [
              {
                "conditions": [
                  { "type": "scoreGreaterThan", "scoreThreshold": 59 }
                ],
                "then": "visible"
              }
            ]
          }
        },
        "results-fail": {
          "type": "text",
          "rect": { "x": 140, "y": 300, "w": 1000, "h": 60 },
          "content": "Keep going, %LearnerName% — try again.",
          "style": {
            "fontSize": 44,
            "fontWeight": "700",
            "color": "#F87171",
            "textAlign": "center"
          },
          "visibility": {
            "initial": "hidden",
            "conditional": [
              {
                "conditions": [
                  { "type": "scoreLessThan", "scoreThreshold": 60 }
                ],
                "then": "visible"
              }
            ]
          }
        },
        "results-sub": {
          "type": "text",
          "rect": { "x": 140, "y": 400, "w": 1000, "h": 50 },
          "content": "That's every interaction the runtime supports, rolled into one short course.",
          "style": { "fontSize": 20, "color": "#CBD5F5", "textAlign": "center" }
        }
      },
      "triggers": []
    }
  ]
}
