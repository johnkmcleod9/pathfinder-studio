        }
      ]
    },
    {
      "id": "q4-match-seq",
      "title": "Quiz — matching + sequencing",
      "background": { "type": "solid", "color": "#F5F7FA" },
      "zOrder": ["q4-h", "q4-match", "q4-seq", "q4-submit"],
      "objects": {
        "q4-h": {
          "type": "text",
          "rect": { "x": 80, "y": 40, "w": 1120, "h": 50 },
